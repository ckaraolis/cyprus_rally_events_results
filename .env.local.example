# Copy to .env.local and fill in values. Never commit .env.local.
# Paths match the MT1 REST docs: https://alge-results.com/api-doc/

# Full URL for programmatic login (from API documentation).
ALGE_AUTH_URL=https://www.alge-results.com/mt1/api/user/login

# Credentials (Timekeeper account).
ALGE_USERNAME=christoforos.karaolis@gmail.com
ALGE_PASSWORD=Schumy21r!

# JSON field name for your login id if not "username" (e.g. "email").
# ALGE_LOGIN_FIELD=email

# Response field holding the token; tries common names if unset.
# ALGE_TOKEN_JSON_KEY=token

# Base URL for authenticated API calls (no trailing slash).
ALGE_API_BASE=https://alge-results.com

# Optional: only allow proxying paths under this prefix (e.g. api/v1).
# ALGE_ALLOWED_PROXY_PREFIX=

# Authorization header sent to ALGE API (defaults: Bearer token).
# ALGE_AUTHORIZATION_HEADER_NAME=Authorization
# ALGE_AUTHORIZATION_MODE=bearer

# Optional: override token cache duration in ms if response has no expires_in.
# ALGE_TOKEN_CACHE_MS=3600000

# Admin login credentials
# ADMIN_USERNAME=admin
# ADMIN_USERNAMES=admin1,admin2
# ADMIN_PASSWORD=change-me
# ADMIN_SESSION_SECRET=change-me-long-random-secret

# -----------------------------
# PostgreSQL (optional on this machine)
# -----------------------------
# Local development: you do NOT need Postgres or `prisma migrate` here. Use the admin
# site to edit rallies; data is stored under data/rally-site.json when file writes are on.
# Do not run schema migrations from your laptop — apply schema changes in Supabase / your
# hosting pipeline only. This repo no longer ships an npm script for `prisma migrate dev`.
#
# Supabase (production / hosted app only): connection string from Project Settings → Database.
# If you see "Can't reach database server" (P1001): resume the project in Supabase, confirm
# the password, and check your network. Pooler URLs often use port 6543.
#
# Example: postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public
# DATABASE_URL=
#
# Local = JSON only (recommended): leave DATABASE_URL unset or keep DB flags off:
# RALLY_DB_READS=0
# RALLY_DB_WRITES=0
# RALLY_FILE_WRITES=1
#
# Hosted app with Postgres (reads/writes DB + JSON fallback):
# RALLY_DB_READS=1    # 1 = prefer Postgres; also compares updatedAt vs data/rally-site.json
# RALLY_DB_READ_TIMEOUT_MS=8000  # optional; abort slow DB reads and fall back to JSON (ms)
# RALLY_DB_WRITES=1   # 1 = write to DB on each admin save
# RALLY_FILE_WRITES=1 # 1 = keep JSON file writes (recommended so saves survive DB outages)
#
# If the DB is down but JSON still saves, the app serves whichever copy is newer (updatedAt).
